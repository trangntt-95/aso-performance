# Google Sheets credentials — copy this file to .env.local and fill in.
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Paste the private_key from the service-account JSON.
# Newlines MUST be escaped as literal \n (the app un-escapes at runtime).
GOOGLE_SERVICE_ACCOUNT_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
